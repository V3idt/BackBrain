{
  "name": "@backbrain/extension",
  "version": "0.1.0",
  "private": true,
  "displayName": "BackBrain",
  "description": "AI-Powered Code Security & Quality Platform",
  "publisher": "backbrain",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Testing"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "backbrain.scanFile",
        "title": "BackBrain: Scan Current File"
      },
      {
        "command": "backbrain.scanWorkspace",
        "title": "BackBrain: Scan Workspace"
      },
      {
        "command": "backbrain.showSecurityPanel",
        "title": "BackBrain: Show Security Panel"
      },
      {
        "command": "backbrain.explainIssue",
        "title": "BackBrain: Explain Issue with AI"
      },
      {
        "command": "backbrain.suggestFix",
        "title": "BackBrain: Suggest Fix with AI"
      }
    ],
    "configuration": {
      "title": "BackBrain",
      "properties": {
        "backbrain.scanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan files on save"
        },
        "backbrain.excludePaths": {
          "type": "array",
          "default": [
            "node_modules",
            "dist",
            "build",
            ".git"
          ],
          "description": "Paths to exclude from scanning"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backbrain-sidebar",
          "title": "BackBrain",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "backbrain-sidebar": [
        {
          "type": "webview",
          "id": "backbrain.severityPanel",
          "name": "Security Issues"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup && bun run build:webview",
    "build:webview": "vite build",
    "watch": "tsup --watch",
    "typecheck": "tsc --noEmit && tsc -p src/webview/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@backbrain/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.1"
  }
}