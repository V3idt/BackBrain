{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/webview",
        "module": "ESNext",
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "**/*"
    ],
    "exclude": []
}