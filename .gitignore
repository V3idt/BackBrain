# 1. Ignore everything
*

# 2. Allow all directories to be traversed
!*/

# 3. Whitelist root configuration and documentation
!.gitignore
!package.json
!bun.lock
!tsconfig.json
!README.md
!index.ts

# 4. Whitelist source code and assets
!packages/**/*
!packages/**/*.json
!packages/**/*.md
!packages/**/*.png
!packages/**/*.svg
!tests/**/*
!scripts/**/*
!.agent/**/*

# 5. Re-ignore specific directories and files that should NEVER be tracked
node_modules/
dist/
out/
coverage/
.env*
.idea/
.DS_Store
*.tsbuildinfo

# 6. Whitelist documentation
!docs/**/IMPLEMENTATION_PLANS.md
!docs/**/ROADMAP.md


